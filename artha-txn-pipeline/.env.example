# Copy this file to .env before running docker compose up.
# Leave GEMINI_API_KEY blank and LLM_PROVIDER=mock to run the entire
# pipeline with zero spend and zero external dependency (deterministic
# keyword-based classifier stands in for the LLM).

LLM_PROVIDER=mock
GEMINI_API_KEY=
LLM_MODEL=gemini-1.5-flash
MAX_UPLOAD_MB=10
